# Токен вашего Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_сюда

# Ключ API Claude (получить на console.anthropic.com)
ANTHROPIC_API_KEY=ваш_ключ_сюда

# Ваш Telegram ID (узнать у @userinfobot)
MANAGER_CHAT_ID=ваш_id_сюда

# ID Google таблицы (из ссылки на таблицу)
GOOGLE_SHEET_ID=id_таблицы_сюда

# Название вашего магазина
SHOP_NAME=Мой Магазин

# Дополнительная информация о магазине для бота
SHOP_DESCRIPTION=Интернет-магазин качественных товаров. Доставка по всей России.
